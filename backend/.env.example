NODE_ENV=production
PORT=3000

MONGODB_URI=mongodb://127.0.0.1:27017/gest_stock

JWT_SECRET=change_me_with_a_long_random_string
JWT_EXPIRES_IN=7d

CORS_ORIGIN=https://digitboutique.cmidigit.com
SEED_SECRET=change_me_seed_secret

# URL du frontend (base du lien de réinitialisation)
APP_URL=https://digitboutique.cmidigit.com

# SMTP (mailer - mot de passe oublié)
SMTP_HOST=mail.cmidigit.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@cmidigit.com
SMTP_PASS=change_me_mailbox_password
SMTP_FROM=CMIDigit <contact@cmidigit.com>
